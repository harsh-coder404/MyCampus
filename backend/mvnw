#!/bin/sh
set -e

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROPS_FILE="$BASE_DIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$PROPS_FILE" ]; then
  echo "Could not find $PROPS_FILE"
  exit 1
fi

DIST_URL=$(grep '^distributionUrl=' "$PROPS_FILE" | cut -d'=' -f2-)
if [ -z "$DIST_URL" ]; then
  echo "distributionUrl is missing in maven-wrapper.properties"
  exit 1
fi

WRAP_HOME="$HOME/.m2/wrapper/dists/mycampus-backend"
mkdir -p "$WRAP_HOME"

MVN_HOME=$(find "$WRAP_HOME" -maxdepth 1 -type d -name 'apache-maven-*' | head -n 1 || true)

if [ -z "$MVN_HOME" ]; then
  DIST_FILE=$(basename "$DIST_URL")
  ZIP_PATH="$WRAP_HOME/$DIST_FILE"

  if [ ! -f "$ZIP_PATH" ]; then
    echo "Downloading Maven from $DIST_URL"
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$DIST_URL" -o "$ZIP_PATH"
    elif command -v wget >/dev/null 2>&1; then
      wget -q "$DIST_URL" -O "$ZIP_PATH"
    else
      echo "Neither curl nor wget is available to download Maven."
      exit 1
    fi
  fi

  echo "Extracting Maven..."
  if command -v unzip >/dev/null 2>&1; then
    unzip -oq "$ZIP_PATH" -d "$WRAP_HOME"
  else
    echo "unzip is required to extract Maven distribution."
    exit 1
  fi

  MVN_HOME=$(find "$WRAP_HOME" -maxdepth 1 -type d -name 'apache-maven-*' | head -n 1 || true)
fi

if [ -z "$MVN_HOME" ] || [ ! -x "$MVN_HOME/bin/mvn" ]; then
  echo "Maven home could not be resolved."
  exit 1
fi

exec "$MVN_HOME/bin/mvn" "$@"

